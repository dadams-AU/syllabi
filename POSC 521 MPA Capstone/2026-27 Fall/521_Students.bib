@article{mcknight2025,
  title = {Does {{Disclosure Matter}}? {{Coupling Information}} to {{Performance}} in {{Texas}}},
  shorttitle = {Does {{Disclosure Matter}}?},
  author = {McKnight, Steven P. and Adams, David P. and Fisk, Jonathan M.},
  year = 2025,
  month = jul,
  journal = {Policy Studies Journal},
  pages = {psj.70064},
  issn = {0190-292X, 1541-0072},
  doi = {10.1111/psj.70064},
  urldate = {2026-03-14},
  abstract = {ABSTRACT             Policy scholars have explored various policy instruments to understand how states work toward multiple goals. However, little attention has been given to the enforcement of these policies, especially as it relates to how changes relative to the disclosure of information impact policy enforcement and performance. Enforcement, like rule formulation and adoption, involves complex regulatory processes, political dimensions, and potential place-based disputes. Even within one state, enforcement varies significantly over time and across regions due to differences in exigency, staffing, and resources. Addressing this gap, our study focuses on a 2019 policy change in Texas that increased the disclosure of information via public access to information on the locations, frequencies, and results of oil and gas related inspections, violations, and administrative enforcement actions. In short, we ask, does information disclosure matter? Our data reveal a nuanced set of results: while greater disclosure appears to have contributed to a decrease in average monthly violations identified by inspectors, there was a notable increase in the number of enforcement actions taken by state regulators. In short, results highlight the complex relationship among information, transparency, firm behavior, and state enforcement agencies.           ,              摘要             政策学者探索了不同政策工具，以理解各州如何实现多重目标。然而，几乎没有研究聚焦于这些政策的执行，尤其是信息披露相关的变化如何影响政策执行和绩效。执法(如同规则的制定和采用)涉及复杂的监管过程、政治层面、以及潜在的基于地点的争议。即使在同一州内，由于紧急程度、人员配备和资源的差异，执法也会随着时间和地区的变化而存在显著差异。为了填补该研究空白，我们的研究聚焦于德克萨斯州2019年的一项政策变革，该变革增加了信息披露，即公众对``有关石油和天然气相关检查、违规行为和行政执法行动的地点信息、频率信息和结果信息''的获取。简而言之，我们探究:信息披露重要吗?我们的数据揭示了一系列微妙的结果:虽然信息披露的提高似乎有助于减少检查人员发现的每月平均违规数量，但州监管机构采取的执法行动数量却显著增加。总之，结果强调了信息、透明度、公司行为和州执法机构之间的复杂关系。           ,              RESUMEN             Los investigadores de pol\'iticas p\'ublicas han explorado diversos instrumentos para comprender c\'omo los estados trabajan para alcanzar m\'ultiples objetivos. Sin embargo, se ha prestado poca atenci\'on a la aplicaci\'on de estas pol\'iticas, especialmente en lo que respecta a c\'omo los cambios en la divulgaci\'on de informaci\'on impactan la aplicaci\'on y el desempe\~no de las pol\'iticas. La aplicaci\'on, al igual que la formulaci\'on y adopci\'on de normas, implica procesos regulatorios complejos, dimensiones pol\'iticas y posibles disputas locales. Incluso dentro de un mismo estado, la aplicaci\'on var\'ia significativamente a lo largo del tiempo y entre regiones debido a las diferencias en la exigencia, el personal y los recursos. Para abordar esta brecha, nuestro estudio se centra en un cambio de pol\'itica de 2019 en Texas que increment\'o la divulgaci\'on de informaci\'on mediante el acceso p\'ublico a informaci\'on sobre las ubicaciones, la frecuencia y los resultados de las inspecciones, infracciones y acciones administrativas de cumplimiento relacionadas con el petr\'oleo y el gas. En resumen, nos preguntamos: \textquestiondown importa la divulgaci\'on de informaci\'on? Nuestros datos revelan un conjunto de resultados matizados: si bien una mayor divulgaci\'on parece haber contribuido a una disminuci\'on en el promedio mensual de infracciones identificadas por los inspectores, se observ\'o un aumento notable en el n\'umero de acciones de cumplimiento adoptadas por los reguladores estatales. En resumen, los resultados resaltan la compleja relaci\'on entre la informaci\'on, la transparencia, el comportamiento de las empresas y las agencias estatales de cumplimiento.},
  langid = {english},
  keywords = {,cumplimiento,disclosure,divulgacion,enforcement,environment,medio ambiente},
  file = {/home/dadams/Zotero/storage/J3M8GN2D/McKnight et al. - 2025 - Does Disclosure Matter Coupling Information to Performance in Texas.pdf;/home/dadams/Zotero/storage/CJFA4P5N/psj.html}
}

