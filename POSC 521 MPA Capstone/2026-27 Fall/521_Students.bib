@article{rowland2024,
  title = {Political Efficacy and the Perceived Influence of Urban and Rural Residents},
  author = {Rowland, Emily and Duff, Jeremy and Lee, Juheon},
  year = 2024,
  month = feb,
  journal = {Politics \& Policy},
  pages = {polp.12589},
  issn = {1555-5623, 1747-1346},
  doi = {10.1111/polp.12589},
  urldate = {2024-03-02},
  abstract = {Abstract                                           While political scientists have long studied citizens' political efficacy as an important indicator of attitudes toward government, less attention has been devoted to the efficacy of rural or urban residents, which is important given the intensifying rural--urban divide in American society. This study fills this gap by analyzing the 2020 American National Election Studies. Using ordered logistic regression, this study finds that (1) city residents tend to believe that small towns and rural areas have too much influence on government; (2) residents of small towns and rural areas demonstrate lower levels of external efficacy than city residents; and (3) people who believe that small towns and rural areas have too much influence tend to demonstrate high external and internal efficacies, a tendency that is clearer in cities than in other community types. These findings reflect mutual in-group bias and place-based resentment between rural and urban residents in American society.                                         Related Articles                                Peterson, Holly L., Mark K. McBeth, and Michael D. Jones. 2020. ``Policy Process Theory for Rural Studies: Navigating Context and Generalization in Rural Policy.''                 Politics \& Policy                 48(4): 576--617.                 https://doi.org/10.1111/polp.12366                 .                                               Shortall, Sally, and Margaret Alston. 2016. ``To Rural Proof or Not to Rural Proof: A Comparative Analysis.''                 Politics \& Policy                 44(1): 35--55.                 https://doi-org.libproxy.usouthal.edu/10.1111/polp.12144                 .                                               Smith-Walter, Aaron, Holly L. Peterson, Michael D. Jones, and Ashley Nicole Reynolds Marshall. 2016. ``Gun Stories: How Evidence Shapes Firearm Policy in the United States.''                 Politics \& Policy                 44(6): 1053--88.                 https://doi-org.libproxy.usouthal.edu/10.1111/polp.12187                 .                                       ,              Eficacia pol\'itica e influencia percibida de los residentes urbanos y rurales             Si bien los polit\'ologos han estudiado durante mucho tiempo la eficacia pol\'itica de los ciudadanos como un indicador importante de las actitudes hacia el gobierno, se ha prestado menos atenci\'on a la eficacia de los residentes rurales o urbanos, lo cual es importante dada la intensificaci\'on de la divisi\'on rural-urbana en la sociedad estadounidense. Este estudio llena este vac\'io analizando los estudios electorales nacionales estadounidenses de 2020. Utilizando una regresi\'on log\'istica ordenada, este estudio encuentra que (1) los residentes de las ciudades tienden a creer que los pueblos peque\~nos y las \'areas rurales tienen demasiada influencia en el gobierno; (2) los residentes de pueblos peque\~nos y \'areas rurales demuestran niveles m\'as bajos de eficacia externa que los residentes de las ciudades; y (3) las personas que creen que los pueblos peque\~nos y las \'areas rurales tienen demasiada influencia tienden a demostrar altas eficacias externas e internas, una tendencia que es m\'as clara en las ciudades que en otros tipos de comunidades. Estos hallazgos reflejan un sesgo mutuo dentro del grupo y un resentimiento basado en el lugar entre los residentes rurales y urbanos de la sociedad estadounidense.           ,              城乡居民的政治效能感和感知影响力             虽然政治科学家长期以来研究公民的政治效能，将其作为对政府态度的重要指标，但很少有研究聚焦于农村或城市居民的效能，鉴于美国社会城乡差距日益加剧，这一点很重要。本研究通过分析2020年美国国家选举研究，填补了该空白。通过使用有序逻辑回归，本研究发现:(1)城市居民往往认为小城镇和农村地区对政府的影响力过大；(2)小城镇和农村的居民的外部效能水平低于城市居民；(3)认为小城镇和农村地区影响力太大的人往往表现出较高的外部和内部效能，这种趋势在城市比在其他社区类型中更为明显。这些发现反映了美国社会城乡居民之间相互的群体内偏见和地域怨恨。},
  langid = {english},
  file = {/home/dadams/Zotero/storage/FKYJC56C/Rowland et al. - 2024 - Political efficacy and the perceived influence of .pdf}
}

