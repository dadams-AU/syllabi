  pages = {494--521},
  doi = {10.1093/publius/pjr017},
  abstract = {Climate change has routinely been framed as an issue to be addressed through an intergovernmental regime guided by a set of large nations. The evolving reality of climate change policy development, in the U.S. and abroad, relies heavily on sub-national initiative. This article reviews the American climate policy odyssey, examining distinct periods in which respective intergovernmental roles have shifted. It devotes particular attention to the substantial expansion of state involvement between 1998 and 2007 and the more recent experience in which high state and federal engagement has produced a period of contested federalism. It concludes by exploring the growing likelihood that this arena will continue to be dominated in coming years by either state policy or some blending of state and federal authority.},
