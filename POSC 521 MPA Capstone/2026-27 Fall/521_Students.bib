@article{amin2025,
  title = {Plugged in? {{Assessing}} the Distribution of Orphaned Wells},
  shorttitle = {Plugged In?},
  author = {Amin, Alisha and Adams, David P. and Fisk, Jonathan M. and Mayer, Adam F.},
  year = 2025,
  month = sep,
  journal = {Journal of Environmental Policy \& Planning},
  volume = {27},
  number = {5},
  pages = {496--509},
  publisher = {Routledge},
  issn = {1523-908X},
  doi = {10.1080/1523908X.2025.2480289},
  urldate = {2025-12-28},
  abstract = {The number of inactive oil and gas sites across the U.S. has increased, especially following the boom in unconventional extraction. While much policy research focuses on active wells' health and environmental impacts, comparatively less research examines inactive wells without known owners -- termed orphan wells. These orphaned wells, numbering in the thousands, pose significant fiscal liabilities for governments and potential public health risks. This study constructs a novel dataset to assess the relationship between social vulnerability indicators at the census tract level and orphaned well presence. Our findings reveal that rurality is the strongest predictor of orphaned well distribution, with rural areas experiencing a disproportionate burden. Lower income and home values are associated with higher well counts in a non-linear relationship. Surprisingly, tracts with higher non-white populations have fewer wells, challenging conventional environmental justice assumptions. Additionally, social capital, measured by social organizations' presence, is positively associated with well counts, suggesting community engagement's role in well identification. Our findings highlight the need for orphaned well policies that consider the interplay of rurality, income, home value, social capital, and racial composition.},
  keywords = {climate risk,environmental justice,geospatial analysis,natural resources,Regulatory,socioeconomic factors}
}

