@article{duan2026,
  title = {Geopolitical Fragmentation and the Clean Energy Transition: {{How}} Economic Sanctions Hinder Renewable Energy Development},
  shorttitle = {Geopolitical Fragmentation and the Clean Energy Transition},
  author = {Duan, Haipeng and Hu, Leishuo},
  year = 2026,
  month = jul,
  journal = {Energy Policy},
  volume = {214},
  pages = {115232},
  issn = {0301-4215},
  doi = {10.1016/j.enpol.2026.115232},
  urldate = {2026-03-14},
  abstract = {In an increasingly fragmented geopolitical landscape, the global clean energy transition faces rising uncertainty and disruption. Economic sanctions---often deployed for political objectives---may nonetheless constrain the expansion of renewable energy by weakening access to external finance and limiting international cooperation. Using a panel of 129 countries and regions from 2009 to 2022, this study examines the relationship between economic sanctions and renewable energy development, measured as net renewable electricity generation. The baseline estimates show that sanction episodes are associated with significantly lower renewable generation, with the adverse effects being more pronounced during the growth stage of renewable technology deployment. When sanction types are examined separately, financial and travel-related sanctions display the strongest negative associations. Additional analyses provide evidence consistent with two channels: sanctions coincide with tighter external financing conditions and reduced cross-border mobility of human capital, both of which are important inputs for renewable investment and deployment. The findings are robust to alternative measures of renewable development, including renewable generation capacity, and to a range of robustness and endogeneity checks. Heterogeneity analysis reveals that emerging economies and Asia-Pacific countries experience more pronounced impacts---highlighting structural vulnerabilities and reinforcing energy poverty in the Global South. The results highlight economic sanctions as a non-negligible risk to energy transition pathways, particularly for structurally vulnerable economies, underscoring the need for greater policy coordination to safeguard a just and resilient clean energy transition under geopolitical fragmentation.},
  keywords = {Economic sanctions,Energy transition,Geopolitical fragmentation,Renewable energy},
  file = {/home/dadams/Zotero/storage/UNHYIVST/S0301421526001667.html}
}

