@article{kim2021,
  title = {Supervision of {{Telework}}: {{A Key}} to {{Organizational Performance}}},
  shorttitle = {Supervision of {{Telework}}},
  author = {Kim, Taehee and Mullins, Lauren Bock and Yoon, Taewon},
  year = 2021,
