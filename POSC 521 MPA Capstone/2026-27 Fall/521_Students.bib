  file = {/home/dadams/Zotero/storage/STWA2KIT/ropr.html}
}

@article{nehring2025,
  title = {An {{Evolving Landscape}} for {{Nexus Governance}} in {{Transboundary Basins}}: {{Recognizing}} and {{Harnessing}} the {{Growing Role}} of {{Multistakeholder Platforms}}},
  shorttitle = {An {{Evolving Landscape}} for {{Nexus Governance}} in {{Transboundary Basins}}},
  author = {Nehring, Ryan and Lautze, Jonathan},
  year = 2025,
  month = dec,
  journal = {Society \& Natural Resources},
  volume = {0},
  number = {0},
  pages = {1--11},
  publisher = {Routledge},
  issn = {0894-1920},
  doi = {10.1080/08941920.2025.2606223},
  urldate = {2025-12-28},
  abstract = {In natural resource governance, there has been a drive for increased decentralization through stakeholder engagement. One of the go-to solutions for policymakers and program managers is to develop Multistakeholder Platforms (MSPs). MSPs have become an increasingly common approach to structure sustained and meaningful stakeholder participation. With the proliferation of cooperative arrangements for natural resource governance at a transboundary scale, there has been an increasing number of transboundary river basin MSPs. This perspective reviews the state of research on transboundary MSPs, with a focus on water resource management, to inform a research agenda on transboundary resource governance. We argue that MSPs can be an important mechanism to improve governance in shared basins, depending on the actors, process and context. However, more research is needed to better understand the relationship between cross-sectoral MSPs and existing formal governance institutions. We propose five avenues for research to improve transboundary MSPs in theory and practice.},
  keywords = {Basins,governance,natural resources,stakeholders,transboundary}
}

