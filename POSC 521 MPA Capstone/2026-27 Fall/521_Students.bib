@article{skewes2025,
  title = {Navigating the Energy Transition in {{South America}}: {{Regulatory}} Challenges and Trends in {{Chile}}'s Evolving Energy Legal Landscape},
  shorttitle = {Navigating the Energy Transition in {{South America}}},
  author = {Skewes, Fernanda and Guzm{\'a}n, {\'O}scar and Cort{\'e}s, Juli{\'a}n and Rivera, Marco},
